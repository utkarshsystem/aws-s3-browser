{
  "name": "vcp-s3-browser-ui",
  "version": "1.1.8",
  "description": "S3 Storage Browser React Component Plugin",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "vcp-s3-browser-plugin-ts": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "next": "15.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
